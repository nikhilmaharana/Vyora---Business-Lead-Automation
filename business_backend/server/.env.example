PORT=5000
HOST=127.0.0.1
CLIENT_URL=http://localhost:5173
JWT_SECRET=change-this-secret
MONGO_URI=
# Use the existing Atlas cluster and this database name:
# mongodb+srv://<username>:<password>@<cluster>.mongodb.net/business_leads?retryWrites=true&w=majority
# OTP_MODE=demo is for local development only (OTP is logged to console, no SMTP needed).
OTP_MODE=demo
WHATSAPP_PROVIDER=mock
EMAIL_PROVIDER=mock
PAYMENT_PROVIDER=mock

# Gmail SMTP credentials for OTP email (use App Password)
# Uncomment and fill in for production email delivery:
# EMAIL_USER=your-email@gmail.com
# EMAIL_APP_PASSWORD=your-16-digit-app-password

# MongoDB TLS: Set to 1 to allow invalid certificates (only for local/dev MongoDB instances)
# For MongoDB Atlas (production), leave this unset or set to 0
# MONGO_ALLOW_INVALID_TLS=1